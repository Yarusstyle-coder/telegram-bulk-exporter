# --- Telegram API ---
# Get these from https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- tdl binary ---
# Absolute (or repo-relative) path to the tdl executable. Uncomment to
# override; if unset, the app picks a platform default automatically:
#   Windows        -> ./tools/tdl/tdl.exe
#   Linux / macOS  -> ./tools/tdl/tdl
# TDL_BINARY_PATH=./tools/tdl/tdl.exe
TDL_NAMESPACE=default
# Override tdl's own ~/.tdl/data/<namespace> bolt storage so its peer
# cache and session live under DATA_DIR instead of the user's home dir.
# Keeps every persisted byte on the drive you configured. Default: true.
TDL_USE_LOCAL_STORAGE=true

# --- Storage ---
EXPORT_DIR=./exports
DATA_DIR=./data

# --- Web server ---
WEB_HOST=127.0.0.1
WEB_PORT=8765

# --- Logging ---
LOG_LEVEL=INFO

# --- Security ---
# Auto-lock timeout in seconds for the web UI login session.
# 0 = never auto-lock (stay signed in until you restart the server or log
# out manually) — this is the actual default in src/config.py, suited to a
# single-user dev box. Set a positive number of seconds to force periodic
# re-login (master password + TOTP).
# NOTE: the 2FA page also lets the user pick a lock window from the UI
# (stored in data/user_prefs.json); that per-user choice takes PRIORITY
# over this env var once it's been saved.
AUTO_LOCK_SECONDS=0

# When true, the session token is persisted in the OS-native secret store
# (Windows DPAPI / macOS Keychain / libsecret via `keyring`) so the server
# can restore a "remember on this device" session across restarts without
# re-prompting for the master password. Set to false for maximum safety on
# a shared/multi-user machine — every restart will then require password
# + TOTP again.
PERSIST_SESSIONS=true

# --- Dedup ---
DEDUP_ENABLED=true

# --- Proxy for Telegram (optional) ---
#
# Two ways to declare proxies:
#
# (1) Single URL via PROXY (legacy / simplest):
# PROXY=socks5://127.0.0.1:1080
#
# (2) Pool of multiple proxies via PROXIES — comma- or semicolon-separated;
#     at startup AND every PROXY_TEST_INTERVAL_SECONDS the app pings each
#     entry (TCP-handshake) and picks the fastest as ACTIVE. Dead entries
#     are KEPT in the pool — they're just marked timeout/fail; when the
#     network situation changes (e.g. you switch VPN region) the next
#     auto-test brings them back automatically. UI page /proxy lets you
#     add / remove / re-test on demand.
# PROXIES=socks5://127.0.0.1:1080,mtproto://PROXY_HOST:443?secret=HEX_OR_BASE64_SECRET
#
# Supported schemes:
#   mtproto://host:port?secret=HEX_OR_BASE64
#   mtproxy://...                   (alias of mtproto)
#   https://t.me/proxy?server=...   (Telegram share link, MTProto only)
#   socks5://[user:pass@]host:port
#   socks5h://...                   (remote DNS via the proxy)
#   http://[user:pass@]host:port
#
# IMPORTANT: tdl supports SOCKS5 / SOCKS5H / HTTP only. MTProto entries
# work for Telethon (chat list, avatars). For tdl behind MTProto you need
# a local bridge like https://github.com/9seconds/mtg — start it as
# `mtg run -b 127.0.0.1:1980 mtproto://...` and add `socks5://127.0.0.1:1980`
# to the pool.
PROXY=
PROXIES=

# Auto-pick the fastest entry on startup (and re-pick on each re-attach).
PROXY_AUTO_SELECT=true
PROXY_TEST_INTERVAL_SECONDS=1800
